<!DOCTYPE html>
<html lang="ms">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MuinShop</title>

<style>
body {
  margin:0;
  font-family: Arial;
  background:#f2f2f2;
}

.container {
  max-width:900px;
  margin:auto;
  background:white;
  padding:20px;
}

h1, h2 {
  text-align:center;
}

.banner img {
  width:100%;
  border-radius:15px;
}

.section {
  margin-top:30px;
}

ul {
  padding-left:20px;
}

.testimoni {
  background:#f9f9f9;
  padding:10px;
  border-radius:10px;
  margin-top:10px;
}

.price {
  text-align:center;
  font-size:30px;
  color:red;
}

.old {
  text-decoration: line-through;
  color:gray;
  font-size:18px;
}

.btn {
  display:block;
  text-align:center;
  background:#25D366;
  color:white;
  padding:15px;
  font-size:20px;
  text-decoration:none;
  border-radius:10px;
  margin-top:20px;
}
</style>

</head>

<body>

<div class="container">

<h1>🔥 PRODUK VIRAL 🔥</h1>

<div class="banner">
<img src="https://via.placeholder.com/800x400" alt="produk">
</div>

<div class="section">
<h2>Kelebihan Produk</h2>
<ul>
<li>Mudah digunakan</li>
<li>Harga murah</li>
<li>Kualiti premium</li>
<li>Ramai dah beli</li>
</ul>
</div>

<div class="section">
<h2>Testimoni</h2>
<div class="testimoni">"Memang terbaik!" - Ali</div>
<div class="testimoni">"Berbaloi beli!" - Abu</div>
</div>

<div class="section">
<h2>Harga Promosi</h2>
<p class="price">RM25 <span class="old">RM50</span></p>
</div>

<a class="btn" href="https://wa.me/601XXXXXXXXX">Beli Sekarang (WhatsApp)</a>

</div>

</body>
</html>
